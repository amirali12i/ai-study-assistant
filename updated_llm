import requests
import os
import json
from dotenv import load_dotenv

load_dotenv()

API_KEY = os.getenv("OPENROUTER_API_KEY")
API_URL = "https://openrouter.ai/api/v1/chat/completions"

headers = {
    "Authorization": f"Bearer {API_KEY}",
    "Content-Type": "application/json"
}

MODELS = [
    "google/gemma-4-31b-it:free",
    "nvidia/nemotron-3-super-120b-a12b:free",
    "openai/gpt-oss-120b:free",
]

system_prompt = """
You are a helpful study assistant.

Guidelines:
- Give accurate educational explanations.
- Break difficult topics into simple steps.
- Use examples when useful.
- Be concise unless the user asks for detail.
- Remember important information shared during the conversation.
- Maintain context from previous messages.
"""

history = [{"role": "system", "content": system_prompt}]
memory = []

MAX_HISTORY = 25
MAX_MEMORY = 10

def save_memory():
    with open("memory.json", "w", encoding="utf-8") as f:
        json.dump(memory, f, indent=2)

def load_memory():
    global memory
    try:
        with open("memory.json", "r", encoding="utf-8") as f:
            memory = json.load(f)
    except:
        memory = []

def add_memory(text):
    if len(text.split()) < 4:
        return

    memory.append(text)

    if len(memory) > MAX_MEMORY:
        memory.pop(0)

    save_memory()

def build_messages():
    messages = [{"role": "system", "content": system_prompt}]

    if memory:
        messages.append({
            "role": "system",
            "content": "Relevant memory:\n" + "\n".join(memory)
        })

    messages.extend(history[-MAX_HISTORY:])
    return messages

load_memory()

def ask(user_input):
    history.append({
        "role": "user",
        "content": user_input
    })

    add_memory(user_input)

    for model in MODELS:
        try:
            response = requests.post(
                API_URL,
                headers=headers,
                json={
                    "model": model,
                    "messages": build_messages(),
                    "temperature": 0.7,
                    "max_tokens": 1200
                },
                timeout=40
            )

            if response.status_code != 200:
                continue

            data = response.json()

            if not data.get("choices"):
                continue

            reply = data["choices"][0]["message"]["content"].strip()

            history.append({
                "role": "assistant",
                "content": reply
            })

            add_memory(reply[:200])

            if len(history) > 50:
                history[:] = [history[0]] + history[-49:]

            return reply

        except Exception:
            continue

    history.pop()

    return "⚠️ All models are busy right now. Please try again later."

print("🤖 AI Study Assistant")
print("Type 'memory' to view saved memory")
print("Type 'exit' to quit\n")

while True:
    user_input = input("You: ").strip()

    if not user_input:
        continue

    if user_input.lower() == "exit":
        break

    if user_input.lower() == "memory":
        print("\n".join(memory) if memory else "No memory stored.\n")
        continue

    answer = ask(user_input)

    print(f"\n🤖: {answer}\n")
